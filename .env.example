# Cloudflare (nur für Remote-Wrangler-Operationen / CI nötig)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Sveltia CMS GitHub OAuth:
# NICHT hier und NICHT in der Pages-App hinterlegen!
# Diese Werte gehören als Worker-Secrets in den separaten OAuth-Worker
# (https://github.com/sveltia/sveltia-cms-auth), gesetzt via:
#   bunx wrangler secret put GITHUB_CLIENT_ID
#   bunx wrangler secret put GITHUB_CLIENT_SECRET
# In public/admin/config.yml dann backend.base_url auf die Worker-URL setzen.
